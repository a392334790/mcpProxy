# MCP Auth Proxy 示例配置
MCP_PROXY_LISTEN_ADDR=127.0.0.1:8765
MCP_PROXY_UPSTREAM_MCP_URL=http://127.0.0.1:19000/mcp
MCP_PROXY_AUTHORIZE_URL=http://127.0.0.1:18080/oauth2/authorize
MCP_PROXY_TOKEN_URL=http://127.0.0.1:18080/oauth2/token
MCP_PROXY_CLIENT_ID=local-mcp-proxy
MCP_PROXY_SCOPE=mcp.invoke mcp.read
MCP_PROXY_REDIRECT_URL=http://127.0.0.1:8765/auth/callback
MCP_PROXY_CALLBACK_PATH=/auth/callback
MCP_PROXY_AUTO_OPEN_BROWSER=true
MCP_PROXY_REFRESH_SKEW=60s
MCP_PROXY_LOGIN_STATE_TTL=10m
MCP_PROXY_TOKEN_TIMEOUT=15s
MCP_PROXY_TOKEN_FILE=D:/goProject/mcpProxy/runtime/token.dat

