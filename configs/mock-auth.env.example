# Mock 鉴权中心示例配置
MOCK_AUTH_LISTEN_ADDR=127.0.0.1:18080
MOCK_AUTH_ISSUER=http://127.0.0.1:18080
MOCK_AUTH_CLIENT_ID=local-mcp-proxy
MOCK_AUTH_DEFAULT_USER_ID=u12345
MOCK_AUTH_DEFAULT_USER_NAME=zhangsan
MOCK_AUTH_DEFAULT_SCOPE=mcp.invoke mcp.read
MOCK_AUTH_ACCESS_TTL=5m
MOCK_AUTH_REFRESH_TTL=12h
MOCK_AUTH_CODE_TTL=2m
MOCK_AUTH_INTERACTIVE=false
MOCK_AUTH_AUTO_APPROVE=true
